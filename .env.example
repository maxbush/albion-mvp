# Telegram Bot
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_WEBHOOK_SECRET=random_secret_string
TELEGRAM_WEBHOOK_URL=

# OpenRouter for AI Layer (optional — without it, mock mode is used)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database
DATABASE_URL=sqlite+aiosqlite:///./albion.db

# Application
APP_NAME=ALBION MVP
LOG_LEVEL=INFO

# MeritHub API (OAuth2 + JWT) — Client ID / Secret из Admin Console → API.
# Без них бот прозрачно использует mock-данные.
MERITHUB_CLIENT_ID=
MERITHUB_CLIENT_SECRET=
# Хосты по умолчанию из док MeritHub (можно не трогать):
MERITHUB_SERVICE_HOST=https://serviceaccount1.meritgraph.com
MERITHUB_CLASS_HOST=https://class1.meritgraph.com
MERITHUB_LIVE_HOST=https://live.merithub.com
MERITHUB_TIMEOUT=15.0

# MeritHub webhooks: секрет НЕ обязателен — по доке MeritHub не подписывает пинги,
# приёмник принимает их и так. Задавайте ТОЛЬКО если MeritHub начнёт слать подпись
# (тогда включится проверка). В чат НЕ передавать.
MERITHUB_WEBHOOK_SECRET=
MERITHUB_WEBHOOK_PORT=8000
MERITHUB_WEBHOOK_PATH=/merithub/webhook

# Владельцы/админы пилота — TG ID через запятую.
# Узнать свой TG ID: команда /whoami в боте. Эти аккаунты раздают роли (/role).
ALBION_ADMIN_TELEGRAM_IDS=

# Тайминги сценария неявки (в минутах). Для живого демо поставьте 1.
ALBION_NOTIFY_PARENT_DELAY_MIN=5
ALBION_ESCALATE_DELAY_MIN=15
# Имя тестового ученика для /pilot_absent
ALBION_PILOT_STUDENT_NAME=Пилотный ученик

# Demo mode: creates test users and demo notification on startup
# Set to true ONLY for local development/testing
ALBION_DEMO_MODE=false
